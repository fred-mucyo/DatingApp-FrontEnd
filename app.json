{
  "expo": {
    "scheme": "mutima",
    "name": "Mutima",
    "slug": "uni-dating-beta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.university.unidatingbeta",
      "googleServicesFile": "./google-services.json",
      "newArchEnabled": true
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "b3d5b38f-d933-474c-8b16-1e48c7677ff7"
      }
    },
    "owner": "mucyo_fred"
  }
}
